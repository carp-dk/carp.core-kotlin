{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$ref": "#/$defs/ExecutionReport",
  "$defs": {
    "ExecutionOutputRef": {
      "type": "object",
      "properties": {
        "outputId": { "type": "string", "format": "uuid" },
        "source": { "type": "object", "additionalProperties": true },
        "format": { "type": "string" },
        "schema": { "type": "object", "additionalProperties": true }
      },
      "required": ["outputId", "source", "format", "schema"],
      "additionalProperties": false
    },
    "StepFailure": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["COMMAND_FAILED", "TIMEOUT", "CANCELLED", "INFRASTRUCTURE", "UNKNOWN"]
        },
        "message": { "type": "string" }
      },
      "required": ["kind", "message"],
      "additionalProperties": false
    },
    "StepRunResult": {
      "type": "object",
      "properties": {
        "stepId": { "type": "string", "format": "uuid" },
        "status": { "$ref": "./ExecutionStatus.json" },
        "startedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "finishedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "failure": {
          "oneOf": [
            { "$ref": "#/$defs/StepFailure" },
            { "type": "null" }
          ]
        },
        "outputs": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/ExecutionOutputRef" }
        }
      },
      "required": ["stepId", "status", "startedAt", "finishedAt", "failure", "outputs"],
      "additionalProperties": false
    },
    "ExecutionReport": {
      "$anchor": "ExecutionReport",
      "type": "object",
      "properties": {
        "runId": { "type": "string", "format": "uuid" },
        "status": { "$ref": "./ExecutionStatus.json" },
        "stepResults": {
          "type": "array",
          "items": { "$ref": "#/$defs/StepRunResult" }
        }
      },
      "required": ["runId", "status", "stepResults"],
      "additionalProperties": false
    }
  }
}
