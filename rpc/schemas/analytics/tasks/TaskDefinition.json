{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "title": "TaskDefinition",
  "type": "object",
  "properties": {
    "__type": {
      "const": "taskDefinition"
    },
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": [
        "string",
        "null"
      ]
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "__type",
    "id"
  ],
  "additionalProperties": false
}
