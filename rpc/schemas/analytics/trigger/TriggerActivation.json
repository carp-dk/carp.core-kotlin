{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "title": "TriggerActivation",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "triggerId": {
      "type": "string",
      "format": "uuid"
    },
    "studyId": {
      "type": "string",
      "format": "uuid"
    },
    "firedAt": {
      "type": "string",
      "format": "date-time"
    },
    "workflowExecutionId": {
      "type": ["string", "null"],
      "format": "uuid"
    }
  },
  "required": ["id", "triggerId", "studyId", "firedAt"],
  "additionalProperties": false
