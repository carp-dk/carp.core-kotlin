{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "type": "object",
  "properties": {
    "studyId": { "type": "string", "format": "uuid" },
    "ownerId": { "type": "string", "format": "uuid" },
    "name": { "type": "string" },
    "createdOn": { "type": "string", "format": "date-time" },
    "description": { "type": [ "string", "null" ] },
    "invitation": { "$ref": "../deployments/users/StudyInvitation.json" },
    "versionedProtocolSnapshot": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "../protocols/VersionedStudyProtocolSnapshot.json" }
      ]
    }
  },
  "required": [ "studyId", "ownerId", "name", "createdOn", "description", "invitation", "versionedProtocolSnapshot" ],
  "additionalProperties": false
}
